{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "maree-backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "@types/qs": "^6.15.0",
    "drizzle-kit": "1.0.0-beta.16-ea816b6",
    "husky": "^9.1.7",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@kapso/whatsapp-cloud-api": "^0.1.1",
    "@scalar/hono-api-reference": "^0.9.48",
    "@types/twilio": "^3.19.3",
    "biome": "^0.3.3",
    "dotenv": "^17.3.1",
    "drizzle": "^1.4.0",
    "drizzle-orm": "1.0.0-beta.16-ea816b6",
    "drizzle-seed": "1.0.0-beta.16-ea816b6",
    "drizzle-zod": "^1.0.0-beta.16-ea816b6",
    "googleapis": "^171.4.0",
    "hono": "^4.12.3",
    "hono-compress": "^1.0.2",
    "hono-pino": "^0.10.3",
    "jsonwebtoken": "^9.0.3",
    "orval": "^8.6.2",
    "oxide.ts": "^1.1.0",
    "paseto-ts": "^2.0.5",
    "passkit-generator": "^3.5.7",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "qs": "^6.15.0",
    "twilio": "^5.12.2",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "scripts": {
    "drizzle:up": "&& bunx --bun drizzle-kit up",
    "drizzle:migrate": "bunx --bun drizzle-kit migrate",
    "drizzle:generate": "bunx --bun drizzle-kit generate",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "bunx biome check",
    "check:write": "bunx biome check --write",
    "prepare": "husky",
    "db:start": "cd infra/dev && docker compose up -d",
    "db:stop": "cd infra/dev && docker compose down",
    "ts:check": "bunx tsc --noEmit"
  }
}
