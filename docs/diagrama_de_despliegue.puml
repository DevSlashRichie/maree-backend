@startuml title Diagrama de Despliegue - Sistema Maree (Bun + SWR)

skinparam shadowing false
skinparam roundCorner 0

' =========================
' CLIENTES
' =========================
node "Teléfono" as Phone <<device>> {
    node "Navegador Móvil" <<execution environment>>
}

node "Tablet" as Tablet <<device>> {
    node "Navegador Tablet" <<execution environment>>
}

node "Computadora" as PC <<device>> {
    node "Navegador Web" <<execution environment>>
}

' =========================
' SERVIDOR
' =========================
node "Container App Environment" as CAE <<device>> {
    node "Bun Runtime" <<execution environment>>
}

node "Azure Database" as DB <<device>> {
    node "PostgreSQL" <<execution environment>>
}

' =========================
' ARTEFACTOS
' =========================
artifact "src_frontendapp" <<file>>
artifact "src_backendapp" <<executable>>
artifact "schemas.sql" <<file>>

' =========================
' DEPLOY
' =========================
"src_frontendapp" ..> PC : <<deploy>>
"src_frontendapp" ..> Phone : <<deploy>>
"src_frontendapp" ..> Tablet : <<deploy>>

"src_backendapp" ..> CAE : <<deploy>>
"schemas.sql" ..> CAE : <<deploy>>

' =========================
' RELACIONES CON MULTIPLICIDAD
' =========================
Phone "1..*" -- "1" CAE : HTTPS
PC "1..*" -- "1" CAE : HTTPS
Tablet "1..*" -- "1" CAE : HTTPS

CAE "1" -- "1" DB : TCP/IP

@enduml