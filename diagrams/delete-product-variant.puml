@startuml Product Variant Delete Flow
hide footbox

actor Admin

boundary "ProductVariantDetailComponent" as Component
control "http/product.ts" as Http
control "application/delete-product-variant.ts" as UseCase

Admin ->> Component: delete product variant

Component ->> Http: DELETE /v1/products/variant/{id}
activate Http

Http ->> UseCase: deleteProductVariantUseCase(id)
activate UseCase

create entity "repo/product-repo.ts" as ProductRepo
database "Postgres DB" as DB
UseCase ->> ProductRepo: <<create>>
activate ProductRepo

UseCase ->> ProductRepo: findProductVariantWithComponents(id)
ProductRepo ->> DB: SELECT variant + components WHERE id
activate DB
DB -->> ProductRepo: variant
deactivate DB

alt variant not found
    ProductRepo -->> UseCase: null
    UseCase -->> Http: Err(ProductVariantNotFound)
    Http -->> Component: 404 {"message": "variant not found"}
else variant found
    UseCase ->> ProductRepo: softDeleteVariant(id)
    ProductRepo ->> DB: UPDATE product_variant SET deletedAt
    activate DB
    DB -->> ProductRepo: result
    deactivate DB

    UseCase -->> Http: Ok
    Http -->> Component: 204
end

deactivate ProductRepo
deactivate UseCase
deactivate Http

Component -->> Admin: show deletion confirmation

@enduml

