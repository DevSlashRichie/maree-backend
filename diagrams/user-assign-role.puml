@startuml User Assign Role Flow
hide footbox

actor Admin

boundary "AssignRoleComponent" as Component
control "http/user.ts" as Http
control "application/assign-role.ts" as UseCase

Admin ->> Component: assign role to user

Component ->> Http: POST /v1/users/:userId/roles
activate Http

Http -> Http: AssignRoleDto.safeParseAsync(body)

alt validation fails
    Http -->> Component: 400 {"message": "validation error"}
else validation succeeds
    alt actor.role != administrator
        UseCase -->> Http: Err(ForbiddenError)
        Http -->> Component: 403 {"message": "admin access required"}
    else
        Http ->> UseCase: assignRoleUseCase(actor, userId, {role})
        activate UseCase

        UseCase ->> RbacRepo: <<create>>
        activate RbacRepo

        UseCase ->> RbacRepo: findRoleByName(role)

        create database "Postgres DB" as DB
        RbacRepo ->> DB: SELECT * FROM roles WHERE name = role
        activate DB
        DB -->> RbacRepo: role
        deactivate DB

        alt role not found
            RbacRepo -->> UseCase: null
            UseCase -->> Http: Err(RoleNotFoundError)
            Http -->> Component: 404 {"message": "role not found"}
        else role found
            RbacRepo -->> UseCase: role

            UseCase ->> UserRepo: <<create>>
            activate UserRepo

            UserRepo ->> DB: SELECT * FROM user WHERE id
            activate DB
            DB -->> UserRepo: user
            deactivate DB

            alt user not found
                UseCase -->> Http: Err(UserNotFoundError)
                Http -->> Component: 404 {"message": "user not found"}
            else user found
                RbacRepo ->> DB: DELETE FROM user_roles WHERE userId
                activate DB
                DB -->> RbacRepo: deleted
                deactivate DB

                RbacRepo ->> DB: INSERT INTO user_roles (userId, roleId)
                activate DB
                DB -->> RbacRepo: inserted
                deactivate DB

                UseCase -->> Http: Ok({userId, role})
                Http -->> Component: 200 {userId, role}
            end
        end
        deactivate RbacRepo
        deactivate UserRepo
    end
end

deactivate Http

alt success
    Component -->> Admin: show success message
else error
    Component -->> Admin: show error message
end

@enduml