@startuml Discount Delete Flow
hide footbox

actor Admin

boundary "DiscountDetailPageComponent" as Component
control "http/discount.ts" as Http
control "application/delete-discount.ts" as UseCase

Admin ->> Component: delete discount

Component ->> Http: DELETE /v1/discounts/{id}
activate Http

Http ->> UseCase: deleteDiscountUseCase(id)
activate UseCase

create entity "repo/discount-repo.ts" as DiscountRepo
database "Postgres DB" as DB
UseCase ->> DiscountRepo: <<create>>
activate DiscountRepo

UseCase ->> DiscountRepo: deleteDiscount(id)
DiscountRepo ->> DB: DELETE FROM discount WHERE id
activate DB
DB -->> DiscountRepo: result
deactivate DB

DiscountRepo -->> UseCase: Ok
deactivate DiscountRepo

UseCase -->> Http: Ok
deactivate UseCase

Http -->> Component: 202 {}
deactivate Http

Component -->> Admin: show deletion confirmation

@enduml


