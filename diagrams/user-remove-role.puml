@startuml User Remove Role Flow
hide footbox

actor Admin

boundary "RemoveRoleComponent" as Component
control "http/user.ts" as Http
control "application/remove-role.ts" as UseCase

Admin ->> Component: remove role from user

Component ->> Http: DELETE /v1/users/:userId/roles/:roleName
activate Http

alt actor.role != administrator
    UseCase -->> Http: Err(ForbiddenError)
    Http -->> Component: 403 {"message": "admin access required"}
else
    Http ->> UseCase: removeRoleUseCase(actor, userId, roleName)
    activate UseCase

    create entity "repo/rbac-repo.ts" as RbacRepo
    create entity "repo/user-repo.ts" as UserRepo
    database "Postgres DB" as DB
    UseCase ->> RbacRepo: <<create>>
    UseCase ->> UserRepo: <<create>>

    UseCase ->> RbacRepo: findRoleByName(roleName)

    RbacRepo ->> DB: SELECT * FROM roles WHERE name = roleName
    activate DB
    DB -->> RbacRepo: role
    deactivate DB

    alt role not found
        RbacRepo -->> UseCase: null
        UseCase -->> Http: Err(RoleNotFoundError)
        Http -->> Component: 404 {"message": "role not found"}
    else role found
        RbacRepo -->> UseCase: role

        UseCase ->> UserRepo: findById(userId)

        UserRepo ->> DB: SELECT * FROM user WHERE id
        DB -->> UserRepo: user

        alt user not found
            UseCase -->> Http: Err(UserNotFoundError)
            Http -->> Component: 404 {"message": "user not found"}
        else user found
            UseCase ->> RbacRepo: deleteAllUserRoles(userId)

            RbacRepo ->> DB: DELETE FROM user_roles WHERE userId

            UseCase -->> Http: Ok({userId, role: roleName})
            Http -->> Component: 200 {userId, role: roleName}
        end
    end
    deactivate RbacRepo
    deactivate UserRepo
end

deactivate Http

alt success
    Component -->> Admin: show success message
else error
    Component -->> Admin: show error message
end

@enduml
