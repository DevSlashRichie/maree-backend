@startuml Product And Variant Create Flow
hide footbox

actor Admin

boundary "ProductFormComponent" as Component
control "http/product.ts" as Http
control "application/create-product-and-variant.ts" as UseCase

Admin ->> Component: submit product and variant data

Component ->> Http: POST /v1/products/with-variant
activate Http

Http -> Http: CreateProductAndVariantDto.safeParseAsync(body)

alt validation fails
    Http -->> Component: 400 {"message": "validation error"}
else validation succeeds
    Http ->> UseCase: createProductAndVariantUseCase(data)
    activate UseCase

    create entity "repo/product-repo.ts" as ProductRepo
    database "Postgres DB" as DB
    UseCase ->> ProductRepo: <<create>>
    activate ProductRepo

    UseCase ->> ProductRepo: existsProductVariant(name)
    ProductRepo ->> DB: SELECT COUNT(*) FROM product_variant WHERE name
    activate DB
    DB -->> ProductRepo: count
    deactivate DB

    alt variant already exists
        ProductRepo -->> UseCase: true
        UseCase -->> Http: Err(ProductVariantAlreadyExists)
        Http -->> Component: 400 {"message": "product variant already exists"}
    else variant not exists
        UseCase ->> ProductRepo: existsProduct(name)
        ProductRepo ->> DB: SELECT COUNT(*) FROM product WHERE name
        DB -->> ProductRepo: count

        alt product already exists
            ProductRepo -->> UseCase: true
            UseCase -->> Http: Err(ProductAlreadyExists)
            Http -->> Component: 400 {"message": "product already exists"}
        else product not exists
            UseCase ->> ProductRepo: isIngredientFromCategory(categoryId)
            ProductRepo ->> DB: SELECT * FROM category WHERE id
            DB -->> ProductRepo: category

            UseCase -> UseCase: determine type (ingredient or complete)

            UseCase ->> ProductRepo: saveProduct({name, type, status, categoryId})
            ProductRepo ->> DB: INSERT INTO product
            DB -->> ProductRepo: product

            UseCase ->> ProductRepo: saveProductVariant({name, price, productId})
            ProductRepo ->> DB: INSERT INTO product_variant
            DB -->> ProductRepo: variant

            alt ingredients provided
                UseCase ->> ProductRepo: saveProductComponents(ingredients)
                ProductRepo ->> DB: INSERT INTO product_component
                DB -->> ProductRepo: success
            end

            deactivate ProductRepo
            UseCase -->> Http: Ok({product, variant})
            Http -->> Component: 201 {product, variant}
        end
    end
end

deactivate Http

alt success
    Component -->> Admin: redirect to products
else error
    Component -->> Admin: show error message
end

@enduml

