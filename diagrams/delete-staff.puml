@startuml Staff Delete Flow
hide footbox

actor Administrator

boundary "StaffListComponent" as Component
control "http/staff.ts" as Http
control "application/delete-staff.ts" as UseCase

Administrator ->> Component: delete staff member

Component ->> Http: DELETE /v1/staff/:userId
activate Http

Http ->> UseCase: deleteStaffUseCase(actor, userId)
activate UseCase

alt actor not administrator
    UseCase -->> Http: Err(ForbiddenError)
    Http -->> Component: 403 {"message": "forbidden"}
else administrator
    create entity "repo/user-repo.ts" as UserRepo
    database "Postgres DB" as DB
    UseCase ->> UserRepo: <<create>>
    activate UserRepo

    UseCase ->> UserRepo: findById(userId)

    UserRepo ->> DB: SELECT * FROM user WHERE id = userId
    activate DB
    DB -->> UserRepo: user
    deactivate DB

    alt user not found
        UserRepo -->> UseCase: null
        UseCase -->> Http: Err(UserNotFoundError)
        Http -->> Component: 404 {"message": "user not found"}
    else user found
        UseCase ->> UserRepo: deleteStaff(userId)

        UserRepo ->> DB: DELETE FROM staff WHERE userId = userId
        DB -->> UserRepo: success

        create entity "repo/rbac-repo.ts" as RbacRepo
        UseCase ->> RbacRepo: <<create>>
        activate RbacRepo
        UseCase ->> RbacRepo: deleteAllUserRoles(userId)

        RbacRepo ->> DB: DELETE FROM user_role WHERE userId = userId
        DB -->> RbacRepo: success
        deactivate UserRepo
        deactivate RbacRepo

        UseCase -->> Http: Ok({userId})
        Http -->> Component: 200 {userId}
    end
end

deactivate Http

alt success
    Component -->> Administrator: remove from list
else error
    Component -->> Administrator: show error message
end

@enduml

