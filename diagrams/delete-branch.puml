@startuml Delete Branch Flow
hide footbox

actor User

boundary "BranchComponent" as Component
control "http/branch.ts" as Http
control "application/delete-branch.ts" as UseCase

User ->> Component: request delete branch

Component ->> Http: DELETE /v1/branches/:id
activate Http

Http ->> UseCase: deleteBranchUseCase(id)
activate UseCase

create entity "repo/branch-repo.ts" as BranchRepo
database "Postgres DB" as DB
UseCase ->> BranchRepo: <<create>>
activate BranchRepo

UseCase ->> BranchRepo: findById(id)
BranchRepo ->> DB: SELECT branch WHERE id = id
activate DB
DB -->> BranchRepo: branch
deactivate DB

alt branch not found
    BranchRepo -->> UseCase: null
    UseCase -->> Http: Err(BranchNotFoundError)
    Http -->> Component: 404 {"message": "branch not found"}
else branch found
    UseCase ->> DB: SELECT * FROM staff WHERE branch_id = id
    DB -->> UseCase: staffList

    alt has staff
        UseCase -->> Http: Err(BranchHasStaffError)
        Http -->> Component: 400 {"message": "cannot delete branch with active staff"}
    else no staff
        UseCase ->> DB: SELECT * FROM orders WHERE branch_id = id
        DB -->> UseCase: ordersList

        alt has orders
            UseCase -->> Http: Err(BranchHasOrdersError)
            Http -->> Component: 400 {"message": "cannot delete branch with active orders"}
        else no orders
            UseCase ->> DB: DELETE FROM schedules WHERE branch_id = id
            DB -->> UseCase: deleted

            UseCase ->> DB: DELETE FROM branch WHERE id = id
            DB -->> UseCase: deleted

            UseCase -->> Http: Ok(undefined)
            Http -->> Component: 200 {success: true}
        end
    end
end
deactivate BranchRepo
deactivate UseCase
deactivate Http

alt success
    Component -->> User: branch deleted successfully
else error
    Component -->> User: show error message
end

@enduml