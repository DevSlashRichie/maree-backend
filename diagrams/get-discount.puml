@startuml Discount Get Flow
hide footbox

actor Admin

boundary "DiscountDetailPageComponent" as Component
control "http/discount.ts" as Http
control "application/get-discount.ts" as UseCase

Admin ->> Component: view discount details

Component ->> Http: GET /v1/discounts/{id}
activate Http

Http ->> UseCase: getDiscountUseCase(id)
activate UseCase

create entity "repo/discount-repo.ts" as DiscountRepo
database "Postgres DB" as DB
UseCase ->> DiscountRepo: <<create>>
activate DiscountRepo

UseCase ->> DiscountRepo: findDiscountById(id)

DiscountRepo ->> DB: SELECT * FROM discount WHERE id
activate DB
DB -->> DiscountRepo: discount
deactivate DB

alt discount not found
    DiscountRepo -->> UseCase: null
    UseCase -->> Http: Err(DiscountNotFoundError)
    Http -->> Component: 404 {"message": "discount not found"}
else discount found
    DiscountRepo -->> UseCase: discount
    deactivate DiscountRepo
    UseCase -->> Http: Ok(discount)
    Http -->> Component: 200 {discount}
end

deactivate UseCase
deactivate Http

Component -->> Admin: render discount details

@enduml


